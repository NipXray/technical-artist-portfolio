---
import resume from '../data/resume.json';
---

<section id="skills">
  <div class="mx-auto max-w-7xl px-6 py-20 sm:px-8">
    <p class="text-sm font-bold uppercase tracking-[0.3em] text-accent-2">Toolkit</p>
    <h2 class="mt-2 font-display text-3xl font-extrabold text-paper sm:text-4xl">Skills &amp; Capabilities</h2>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {resume.skills.map((group) => (
        <div class="rounded-2xl bg-ink-800 p-6 transition-colors hover:bg-ink-700">
          <h4 class="text-xs font-bold uppercase tracking-wider text-paper-dim">{group.category}</h4>
          <div class="mt-4 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="rounded-full bg-ink-900 px-3 py-1.5 text-sm font-medium text-paper transition-all duration-150 hover:-translate-y-0.5 hover:text-accent-2">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
