---
import resume from '../data/resume.json';
---

<section id="contact">
  <div class="mx-auto max-w-7xl px-6 py-20 sm:px-8">
    <p class="text-sm font-bold uppercase tracking-[0.3em] text-accent-2">Get In Touch</p>
    <h2 class="mt-2 font-display text-3xl font-extrabold text-paper sm:text-4xl">Let's Work Together</h2>
    <p class="mt-4 max-w-xl text-paper-dim">
      Have a character, world, or effect you'd like brought to life? Send a message, or find me on{' '}
      <a href={resume.githubUrl} target="_blank" rel="noreferrer" class="text-accent-2 hover:underline">GitHub</a>{' '}
      and{' '}
      <a href={resume.artstationUrl} target="_blank" rel="noreferrer" class="text-accent-2 hover:underline">ArtStation</a>.
    </p>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="mt-8 max-w-xl rounded-2xl bg-ink-800 p-6"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden">
        <label>
          Don't fill this out if you're human: <input name="bot-field" />
        </label>
      </p>

      <div class="grid gap-4">
        <label class="block">
          <span class="text-xs font-bold uppercase tracking-wide text-paper-dim">Name</span>
          <input
            type="text"
            name="name"
            required
            class="mt-1 w-full rounded-lg bg-ink-900 px-3 py-2 text-paper outline-none ring-1 ring-transparent transition-all focus:ring-accent"
          />
        </label>

        <label class="block">
          <span class="text-xs font-bold uppercase tracking-wide text-paper-dim">Email</span>
          <input
            type="email"
            name="email"
            required
            class="mt-1 w-full rounded-lg bg-ink-900 px-3 py-2 text-paper outline-none ring-1 ring-transparent transition-all focus:ring-accent"
          />
        </label>

        <label class="block">
          <span class="text-xs font-bold uppercase tracking-wide text-paper-dim">Message</span>
          <textarea
            name="message"
            rows="5"
            required
            class="mt-1 w-full rounded-lg bg-ink-900 px-3 py-2 text-paper outline-none ring-1 ring-transparent transition-all focus:ring-accent"
          ></textarea>
        </label>

        <button
          type="submit"
          class="rounded-none bg-accent px-6 py-3 text-sm font-bold uppercase tracking-wide text-ink-950 transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent-2"
        >
          Send Message
        </button>
      </div>
    </form>
  </div>
</section>
