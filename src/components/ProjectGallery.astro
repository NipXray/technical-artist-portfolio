---
import { getCollection } from 'astro:content';
import ProjectShowcase from './ProjectShowcase';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((project) => ({
    slug: project.data.slug,
    title: project.data.title,
    cover: project.data.cover,
    gallery: project.data.gallery,
    video: project.data.video,
    description: project.data.description,
    techStack: project.data.techStack,
    clickEffect: project.data.clickEffect,
    ambientEffect: project.data.ambientEffect,
    ambientEffectScope: project.data.ambientEffectScope,
    ambientVideoUrl: project.data.ambientVideoUrl,
    galleryVideoPlayback: project.data.galleryVideoPlayback
  }));
---

<section id="projects">
  <div class="mx-auto max-w-7xl px-6 pb-10 pt-24 sm:px-8">
    <p class="text-sm font-bold uppercase tracking-[0.3em] text-accent-2">Portfolio</p>
    <h2 class="mt-2 font-display text-3xl font-extrabold text-paper sm:text-4xl">Selected Work</h2>
    <p class="mt-2 text-paper-dim">Hover to explore. Click a piece to open it.</p>
  </div>

  <ProjectShowcase client:visible projects={projects} />
</section>
