---
import resume from '../data/resume.json';
import HeroSlideshow from './HeroSlideshow';
---

<section class="relative flex h-screen min-h-[640px] items-end overflow-hidden">
  <HeroSlideshow client:load slides={resume.heroSlides ?? []} />

  <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/60 to-ink-950/10"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-ink-950/70 via-transparent to-transparent"></div>

  <div class="relative mx-auto w-full max-w-7xl px-6 pb-24 pt-40 sm:px-8">
    <p class="mb-4 text-sm font-bold uppercase tracking-[0.3em] text-accent-2">3D Artist</p>
    <h1 class="max-w-3xl font-display text-5xl font-extrabold leading-[1.05] text-paper sm:text-6xl lg:text-7xl">
      {resume.title}
    </h1>
    <p class="mt-6 max-w-xl text-lg text-paper-dim">
      {resume.tagline}
    </p>
    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a
        href="#projects"
        class="rounded-full bg-accent px-7 py-3.5 text-sm font-bold uppercase tracking-wide text-ink-950 transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent-2"
      >
        View Projects
      </a>
      <a
        href={resume.cvUrl}
        download
        class="rounded-full border-2 border-paper/30 px-7 py-3.5 text-sm font-bold uppercase tracking-wide text-paper transition-all duration-200 hover:-translate-y-0.5 hover:border-paper hover:bg-paper/10"
      >
        Download Resume
      </a>
    </div>
  </div>
</section>
