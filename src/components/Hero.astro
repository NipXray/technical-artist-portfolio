---
import resume from '../data/resume.json';
---

<section class="relative flex min-h-[85vh] items-center overflow-hidden border-b border-border">
  <div id="hero-grid" class="grid-bg absolute inset-0 -inset-y-20"></div>

  <video
    class="absolute inset-0 h-full w-full object-cover opacity-30"
    autoplay
    muted
    loop
    playsinline
    poster="/videos/reel-poster.svg"
    onerror="this.style.display='none'"
  >
    <source src={resume.reelVideoUrl} type="video/mp4" />
  </video>

  <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/70 to-ink-950/20"></div>

  <div class="relative mx-auto max-w-6xl px-6 py-24">
    <p class="mb-4 font-mono text-sm text-accent">// technical artist</p>
    <h1 class="max-w-3xl text-4xl font-bold leading-tight text-paper sm:text-5xl lg:text-6xl">
      {resume.title}
    </h1>
    <p class="mt-6 max-w-xl text-lg text-paper-dim">
      {resume.tagline}
    </p>
    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a
        href="#projects"
        class="rounded-lg bg-accent px-5 py-3 font-mono text-sm font-medium text-ink-950 transition-transform duration-200 hover:-translate-y-0.5 hover:scale-105"
      >
        view_projects()
      </a>
      <a
        href={resume.cvUrl}
        download
        class="rounded-lg border border-border px-5 py-3 font-mono text-sm text-paper transition-all duration-200 hover:-translate-y-0.5 hover:border-accent hover:text-accent"
      >
        ↓ download_cv.pdf
      </a>
    </div>
  </div>
</section>

<script>
  const grid = document.getElementById('hero-grid');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (grid && !prefersReducedMotion) {
    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          grid.style.transform = `translate3d(0, ${window.scrollY * 0.25}px, 0)`;
          ticking = false;
        });
      },
      { passive: true }
    );
  }
</script>
