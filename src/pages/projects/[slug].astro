---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getEmbedUrl } from '../../lib/embed';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const embedUrl = getEmbedUrl(project.data.video);
const extraImages = project.data.gallery.filter((src) => src !== project.data.cover);
const VIDEO_EXTENSION = /\.(mp4|webm|mov|m4v)$/i;
---

<Layout title={project.data.title} description={project.data.description}>
  <article class="mx-auto max-w-3xl px-6 pb-16 pt-32 sm:pt-36">
    <a href="/#projects" class="text-sm font-semibold text-paper-dim transition-colors hover:text-accent-2">&larr; Back to projects</a>

    <div id="case-study-content" data-slug={project.data.slug}>
    <h1 class="mt-4 font-display text-3xl font-extrabold text-paper sm:text-4xl">{project.data.title}</h1>
    <p class="mt-3 text-lg text-paper-dim">{project.data.description}</p>

    <div class="mt-4 flex flex-wrap gap-2">
      {project.data.techStack.map((tech) => (
        <span class="rounded-none border border-border px-3 py-1 text-xs font-semibold text-accent-2">
          {tech}
        </span>
      ))}
    </div>

    {embedUrl && (
      <div class="mt-8 aspect-video overflow-hidden rounded-2xl bg-ink-900">
        <iframe
          class="h-full w-full"
          src={embedUrl}
          title={`${project.data.title} video`}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    )}

    {!embedUrl && (
      <img
        src={project.data.cover}
        alt={project.data.title}
        class="mt-8 w-full rounded-2xl object-cover"
      />
    )}

    {extraImages.length > 0 && (
      <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3">
        {extraImages.map((src) => (
          VIDEO_EXTENSION.test(src) ? (
            <video src={src} muted loop autoplay playsinline class="aspect-video w-full rounded-xl object-cover" />
          ) : (
            <img src={src} alt={project.data.title} class="aspect-video w-full rounded-xl object-cover" />
          )
        ))}
      </div>
    )}

    {project.data.model && (
      <div class="mt-8">
        <p class="mb-2 text-sm font-semibold text-paper-dim">Interactive 3D preview — drag to rotate, scroll to zoom</p>
        <model-viewer
          src={project.data.model}
          alt={`Interactive 3D preview of ${project.data.title}`}
          camera-controls
          auto-rotate
          ar
          shadow-intensity="1"
          class="h-[420px] w-full rounded-2xl bg-ink-900"
        ></model-viewer>
      </div>
    )}

    <div class="prose prose-invert prose-headings:font-display prose-a:text-accent-2 mt-10 max-w-none">
      <Content />
    </div>
    </div>
  </article>
</Layout>

<script>
  import '@google/model-viewer';
</script>
