---
import '../styles/global.css';
import resume from '../data/resume.json';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = resume.tagline
} = Astro.props;

const navLinks = [
  { href: '/#projects', label: 'projects' },
  { href: '/#skills', label: 'skills' },
  { href: '/#contact', label: 'contact' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · {resume.name}</title>
  </head>
  <body class="min-h-screen bg-ink-950 text-paper antialiased">
    <header class="sticky top-0 z-50 border-b border-border bg-ink-950/80 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="font-mono text-sm text-paper hover:text-accent">
          <span class="text-paper-dim">~/</span>{resume.name.toLowerCase().replace(/\s+/g, '-')}
        </a>
        <nav class="flex items-center gap-6 font-mono text-sm text-paper-dim">
          {navLinks.map((link) => (
            <a href={link.href} class="transition-colors hover:text-accent">{link.label}</a>
          ))}
          <a
            href={resume.cvUrl}
            download
            class="rounded border border-accent/40 px-3 py-1.5 text-accent transition-colors hover:bg-accent hover:text-ink-950"
          >
            resume.pdf
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-border">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-8 font-mono text-xs text-paper-dim sm:flex-row">
        <p>&copy; {new Date().getFullYear()} {resume.name}. All rights reserved.</p>
        <div class="flex gap-4">
          <a href={resume.githubUrl} class="hover:text-accent" target="_blank" rel="noreferrer">github</a>
          <a href={resume.artstationUrl} class="hover:text-accent" target="_blank" rel="noreferrer">artstation</a>
          <a href={`mailto:${resume.email}`} class="hover:text-accent">{resume.email}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
