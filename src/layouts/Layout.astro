---
import { getCollection } from 'astro:content';
import '../styles/global.css';
import resume from '../data/resume.json';
import HistorySidebar from '../components/HistorySidebar';
import ClickEffectLayer from '../components/ClickEffectLayer';
import FloatingSocialDock from '../components/FloatingSocialDock';

const isUrl = (value?: string) => !!value && /^https?:\/\//.test(value);

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = resume.tagline
} = Astro.props;

const navLinks = [
  { href: '/#projects', label: 'Projects' },
  { href: '/#skills', label: 'Skills' },
  { href: '/#contact', label: 'Contact' }
];

const historyEntries = (await getCollection('history'))
  .map((entry) => entry.data)
  .sort((a, b) => a.date.localeCompare(b.date));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · {resume.name}</title>
    <script is:inline>
      (function () {
        if (window.location.pathname !== '/') return;
        if (sessionStorage.getItem('intro-seen') === '1') return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        document.documentElement.classList.add('intro-veil');
      })();
    </script>
  </head>
  <body class="min-h-screen bg-ink-950 text-paper antialiased">
    <header class="fixed inset-x-0 top-0 z-50 bg-gradient-to-b from-ink-950/90 to-transparent">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-5 sm:px-8">
        <a href="/" class="truncate font-display text-lg font-extrabold tracking-tight text-paper hover:text-accent-2">
          {resume.name}
        </a>
        <nav class="flex items-center gap-4 text-sm font-semibold uppercase tracking-wider text-paper-dim sm:gap-8">
          {navLinks.map((link) => (
            <a href={link.href} class="hidden transition-colors hover:text-accent-2 sm:inline">{link.label}</a>
          ))}
          <button id="history-trigger" class="transition-colors hover:text-accent-2">History</button>
          <a
            href={resume.cvUrl}
            download
            class="whitespace-nowrap rounded-none bg-accent px-4 py-2 text-xs font-bold uppercase tracking-wider text-ink-950 transition-all duration-150 hover:-translate-y-0.5 hover:bg-accent-2"
          >
            Resume
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-border">
      <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-8 text-xs text-paper-dim sm:flex-row">
        <p>&copy; {new Date().getFullYear()} {resume.name}. All rights reserved.</p>
        <div class="flex gap-5 font-semibold uppercase tracking-wide">
          {isUrl(resume.githubUrl) && (
            <a href={resume.githubUrl} class="hover:text-accent-2" target="_blank" rel="noreferrer">GitHub</a>
          )}
          {isUrl(resume.artstationUrl) && (
            <a href={resume.artstationUrl} class="hover:text-accent-2" target="_blank" rel="noreferrer">ArtStation</a>
          )}
          <a href={`mailto:${resume.email}`} class="hover:text-accent-2">{resume.email}</a>
        </div>
      </div>
    </footer>

    <HistorySidebar client:load entries={historyEntries} />
    <ClickEffectLayer client:load />
    <FloatingSocialDock
      client:load
      githubUrl={isUrl(resume.githubUrl) ? resume.githubUrl : undefined}
      artstationUrl={isUrl(resume.artstationUrl) ? resume.artstationUrl : undefined}
      youtubeUrl={isUrl(resume.youtubeUrl) ? resume.youtubeUrl : undefined}
      xUrl={isUrl(resume.xUrl) ? resume.xUrl : undefined}
      instagramUrl={isUrl(resume.instagramUrl) ? resume.instagramUrl : undefined}
      linkedinUrl={isUrl(resume.linkedinUrl) ? resume.linkedinUrl : undefined}
    />
  </body>
</html>
