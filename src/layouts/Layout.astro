---
import { getCollection } from 'astro:content';
import '../styles/global.css';
import resume from '../data/resume.json';
import HistorySidebar from '../components/HistorySidebar';
import ClickEffectLayer from '../components/ClickEffectLayer';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = resume.tagline
} = Astro.props;

const navLinks = [
  { href: '/#projects', label: 'projects' },
  { href: '/#skills', label: 'skills' },
  { href: '/#contact', label: 'contact' }
];

const historyEntries = (await getCollection('history'))
  .map((entry) => entry.data)
  .sort((a, b) => a.date.localeCompare(b.date));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · {resume.name}</title>
  </head>
  <body class="min-h-screen bg-ink-950 text-paper antialiased">
    <header class="sticky top-0 z-50 border-b border-border bg-ink-950/80 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-4 sm:px-6">
        <a href="/" class="max-w-[40vw] truncate font-mono text-sm text-paper hover:text-accent sm:max-w-none">
          <span class="text-paper-dim">~/</span>{resume.name.toLowerCase().replace(/\s+/g, '-')}
        </a>
        <nav class="flex items-center gap-3 font-mono text-sm text-paper-dim sm:gap-6">
          {navLinks.map((link) => (
            <a href={link.href} class="hidden transition-colors hover:text-accent sm:inline">{link.label}</a>
          ))}
          <button id="history-trigger" class="transition-colors hover:text-accent">history</button>
          <a
            href={resume.cvUrl}
            download
            class="whitespace-nowrap rounded-lg border border-accent/40 px-2.5 py-1.5 text-accent transition-all duration-150 hover:-translate-y-0.5 hover:bg-accent hover:text-ink-950 sm:px-3"
          >
            resume.pdf
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-border">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-8 font-mono text-xs text-paper-dim sm:flex-row">
        <p>&copy; {new Date().getFullYear()} {resume.name}. All rights reserved.</p>
        <div class="flex gap-4">
          <a href={resume.githubUrl} class="hover:text-accent" target="_blank" rel="noreferrer">github</a>
          <a href={resume.artstationUrl} class="hover:text-accent" target="_blank" rel="noreferrer">artstation</a>
          <a href={`mailto:${resume.email}`} class="hover:text-accent">{resume.email}</a>
        </div>
      </div>
    </footer>

    <HistorySidebar client:load entries={historyEntries} />
    <ClickEffectLayer client:load />
  </body>
</html>
